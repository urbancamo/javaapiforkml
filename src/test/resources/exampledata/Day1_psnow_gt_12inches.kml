<Document id="d1_s_12">
<name>Day 1 WPC PRBLTY of Snow &gt; 12"</name>
  <open>1</open>
  <snippet>Valid 12Z 04/10/2026 - 12Z 04/11/2026</snippet>
  <description>
    <![CDATA[
      <table border=0 width="350"><tr><td>
        <span style="font-size:1em;font-weight:bold;">
	  Issued: 0831Z FRI APR 10, 2026</span></td></tr>
	<tr><td>
	<span style="font-size:1em;font-weight:bold;">
	  Valid: 12Z FRI APR 10, 2026 - 12Z SAT APR 11, 2026</span></td></tr>
	<tr><td>
	<span style="font-size:1em;font-weight:bold;">
	  Forecaster: WPC-WWD</span></td></tr>
	<tr><td><br>
	  <img src="https://www.wpc.ncep.noaa.gov/images/balloon_legend.png">
	</td></tr>
	<tr><td>
          View additional WPC Winter Weather products at:<br>
          https://www.wpc.ncep.noaa.gov/wwd/winter_wx.shtml
	</font>
	</td></tr></table>
    ]]>
  </description>
    <Style id="poly_none">
        <IconStyle>
	    <scale>0.7</scale>
	    <Icon>
	      <href>https://www.wpc.ncep.noaa.gov/images/gray_circle.png</href>
	    </Icon>
	</IconStyle>
	<LabelStyle>
	    <color>ffCCCCCC</color>
	    <scale>1.0</scale>
	</LabelStyle>
	<BalloonStyle>
	  <text>
	    <![CDATA[ <table border=0 width="300"><tr><td><font size="+1">
	    The probability of snow accumulating greater than <b>12 Inches</b> is <b>less than 10%</b> in this enclosed area.
	    <br/><br/>
	    <b>$[id]</b>
	    <br/><br/></font>
	    </td></tr></table>]]>
	  </text>
	</BalloonStyle>
    </Style>
    
